# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# ---- LLM API keys ----

# Closed reasoning + non-reasoning models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: DeepSeek's own API (cheapest way to hit R1 frontier without GPUs)
DEEPSEEK_API_KEY=

# Optional: hosted open-weight inference (Together, Fireworks, Groq, OpenRouter)
# Pick one for Phase 1; switch to local vLLM in Phase 3.
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=

# ---- Google Cloud ----

# Bucket holding the raw + normalized puzzle data.
# Phase 1 reads puzzles from here; results write back to a `results/` prefix.
GCS_BUCKET_NAME=cot-rosetta-interp-data

# Path for application default credentials. cloud-bootstrap manages this
# at session start, so leave blank unless running outside a Claude Code session.
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Cost discipline ----

# Hard ceiling per `run.py` invocation, in USD. Scripts must respect this.
# Default low; raise explicitly per experiment.
MAX_USD_BUDGET=5.00

# Dry-run mode: when "1", model calls are mocked. Flip to "0" for live runs.
DRY_RUN=1
