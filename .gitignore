# ---- Secrets ----
.env
*.pem
*.key
# Note: .cloud-credentials.*.enc files from cloud-bootstrap ARE committed
# (they're encrypted). Only the plaintext .env stays out.

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.pyright/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Virtualenvs ----
.venv/
venv/
env/
.env.local

# ---- uv ----
.uv/

# ---- Notebooks ----
.ipynb_checkpoints/
*.ipynb_meta

# ---- Project data ----
# Raw puzzles live in GCS, not in the repo
data/puzzles-raw/
data/puzzles/

# Experiment outputs (potentially large, definitely not source)
results/
experiments/*/results/
*.parquet
*.jsonl
*.csv
